#!/bin/bash
# NDI Bridge Intercom Status Display
# Shows comprehensive intercom system status

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo "=================================="
echo "   NDI Bridge Intercom Status"
echo "=================================="
echo ""

# Check service status
echo -e "${BLUE}Service Status:${NC}"
if systemctl is-active --quiet ndi-bridge-intercom.service; then
    echo -e "  Service: ${GREEN}● Running${NC}"
    
    # Get service uptime
    uptime=$(systemctl show ndi-bridge-intercom.service --property=ActiveEnterTimestamp | cut -d'=' -f2-)
    if [ -n "$uptime" ]; then
        echo "  Started: $uptime"
    fi
    
    # Get PID
    pid=$(systemctl show ndi-bridge-intercom.service --property=MainPID | cut -d'=' -f2)
    if [ "$pid" != "0" ]; then
        echo "  PID: $pid"
    fi
else
    echo -e "  Service: ${RED}● Stopped${NC}"
fi
echo ""

# Check audio status
echo -e "${BLUE}Audio Configuration:${NC}"
status=$(/usr/local/bin/ndi-bridge-intercom-control status 2>/dev/null)

if [ -n "$status" ]; then
    # Parse output device info
    output_volume=$(echo "$status" | grep -A2 '"output"' | grep '"volume"' | grep -oP '\d+')
    output_muted=$(echo "$status" | grep -A2 '"output"' | grep '"muted"' | awk -F: '{print $2}' | tr -d ' ,')
    output_device=$(echo "$status" | grep -A2 '"output"' | grep '"device"' | cut -d'"' -f4)
    
    # Parse input device info
    input_volume=$(echo "$status" | grep -A2 '"input"' | grep '"volume"' | grep -oP '\d+')
    input_muted=$(echo "$status" | grep -A2 '"input"' | grep '"muted"' | awk -F: '{print $2}' | tr -d ' ,')
    input_device=$(echo "$status" | grep -A2 '"input"' | grep '"device"' | cut -d'"' -f4)
    
    echo "  Output (Speakers):"
    echo "    Device: ${output_device:-Not found}"
    echo -n "    Volume: ${output_volume:-0}% "
    if [ "$output_muted" = "true" ]; then
        echo -e "${RED}[MUTED]${NC}"
    else
        echo -e "${GREEN}[ACTIVE]${NC}"
    fi
    
    echo ""
    echo "  Input (Microphone):"
    echo "    Device: ${input_device:-Not found}"
    echo -n "    Volume: ${input_volume:-0}% "
    if [ "$input_muted" = "true" ]; then
        echo -e "${RED}[MUTED]${NC}"
    else
        echo -e "${GREEN}[ACTIVE]${NC}"
    fi
else
    echo -e "  ${YELLOW}Unable to get audio status${NC}"
    echo "  (Service may not be running or audio devices not available)"
fi
echo ""

# Check VDO.Ninja connection
echo -e "${BLUE}VDO.Ninja Connection:${NC}"
ROOM="${VDO_ROOM:-nl_interkom}"
echo "  Room: $ROOM"
HOSTNAME=$(hostname)
echo "  Device Name: ${HOSTNAME#ndi-bridge-}"

# Check if Chrome is running
if pgrep -f "chrome.*vdo.ninja" > /dev/null 2>&1; then
    echo -e "  Chrome: ${GREEN}● Running${NC}"
    
    # Get Chrome memory usage
    chrome_mem=$(ps aux | grep -E "chrome.*vdo.ninja" | grep -v grep | awk '{sum+=$6} END {printf "%.1f", sum/1024}')
    if [ -n "$chrome_mem" ]; then
        echo "  Memory Usage: ${chrome_mem} MB"
    fi
else
    echo -e "  Chrome: ${YELLOW}○ Not Running${NC}"
fi

# Check PipeWire
if pgrep pipewire > /dev/null 2>&1; then
    echo -e "  PipeWire: ${GREEN}● Running${NC}"
else
    echo -e "  PipeWire: ${RED}○ Not Running${NC}"
fi

# Check VNC server
if pgrep x11vnc > /dev/null 2>&1; then
    echo -e "  VNC Server: ${GREEN}● Running${NC} (Port 5999)"
else
    echo -e "  VNC Server: ${YELLOW}○ Not Running${NC}"
fi
echo ""

# Check saved defaults
echo -e "${BLUE}Default Configuration:${NC}"
if [ -f /etc/ndi-bridge/intercom.conf ]; then
    source /etc/ndi-bridge/intercom.conf
    echo "  Output Volume: ${INTERCOM_OUTPUT_VOLUME}%"
    echo "  Input Volume: ${INTERCOM_INPUT_VOLUME}%"
    echo "  Output Muted: ${INTERCOM_OUTPUT_MUTED}"
    echo "  Input Muted: ${INTERCOM_INPUT_MUTED}"
else
    echo "  No defaults saved (using factory defaults)"
fi
echo ""

# System resources
echo -e "${BLUE}System Resources:${NC}"
# Get total memory usage for intercom components
total_mem=$(ps aux | grep -E "(chrome|pipewire|x11vnc)" | grep -v grep | awk '{sum+=$6} END {printf "%.1f", sum/1024}')
total_cpu=$(ps aux | grep -E "(chrome|pipewire|x11vnc)" | grep -v grep | awk '{sum+=$3} END {print sum}')

echo "  Total Memory: ${total_mem:-0} MB"
echo "  Total CPU: ${total_cpu:-0}%"
echo ""

# Quick help
echo -e "${BLUE}Quick Commands:${NC}"
echo "  ndi-bridge-intercom-control mute      - Mute all audio"
echo "  ndi-bridge-intercom-control unmute    - Unmute all audio"
echo "  ndi-bridge-intercom-control volume both 75  - Set volume to 75%"
echo "  ndi-bridge-intercom-config save       - Save current as defaults"
echo "  ndi-bridge-intercom-restart           - Restart intercom service"
echo ""
echo "=================================="