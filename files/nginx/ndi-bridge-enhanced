server {
    listen 80 default_server;
    listen [::]:80 default_server;
    
    server_name _;
    
    # Basic authentication (except for API endpoints)
    auth_basic "NDI Bridge Login";
    auth_basic_user_file /etc/nginx/.htpasswd;
    
    # Root directory for static files
    root /var/www/ndi-bridge;
    
    # Main dashboard
    location = / {
        try_files /index.html =404;
    }
    
    # Intercom control interface
    location = /intercom {
        auth_basic "NDI Bridge Login";
        auth_basic_user_file /etc/nginx/.htpasswd;
        try_files /intercom.html =404;
    }
    
    location = /intercom.html {
        auth_basic "NDI Bridge Login";
        auth_basic_user_file /etc/nginx/.htpasswd;
    }
    
    # Static assets (CSS, JS, images)
    location ~* \.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot)$ {
        auth_basic off;  # No auth for static assets
        expires 1h;
        add_header Cache-Control "public, immutable";
    }
    
    # API endpoints for intercom control
    location /api/intercom/ {
        auth_basic off;  # API handles its own auth if needed
        
        # CORS headers
        add_header 'Access-Control-Allow-Origin' '*' always;
        add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS' always;
        add_header 'Access-Control-Allow-Headers' 'Content-Type, Authorization' always;
        
        if ($request_method = 'OPTIONS') {
            return 204;
        }
        
        # Proxy to Python API server
        proxy_pass http://127.0.0.1:8089;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Timeouts
        proxy_connect_timeout 10s;
        proxy_send_timeout 10s;
        proxy_read_timeout 10s;
    }
    
    # WebSocket endpoint for real-time updates (future enhancement)
    location /ws/intercom {
        auth_basic off;
        
        proxy_pass http://127.0.0.1:8089;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 86400;
        
        # Disable buffering for WebSocket
        proxy_buffering off;
        proxy_request_buffering off;
    }
    
    # Terminal interface (wetty)
    location /terminal {
        auth_basic "NDI Bridge Login";
        auth_basic_user_file /etc/nginx/.htpasswd;
        
        proxy_pass http://127.0.0.1:7681;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
        
        # Disable buffering for WebSocket
        proxy_buffering off;
        proxy_request_buffering off;
    }
    
    # System status API (future)
    location /api/system/ {
        auth_basic "NDI Bridge Login";
        auth_basic_user_file /etc/nginx/.htpasswd;
        
        # Placeholder for system status API
        return 503 '{"error": "System API not yet implemented"}';
        add_header Content-Type application/json;
    }
    
    # NDI control API (future)
    location /api/ndi/ {
        auth_basic "NDI Bridge Login";
        auth_basic_user_file /etc/nginx/.htpasswd;
        
        # Placeholder for NDI control API
        return 503 '{"error": "NDI API not yet implemented"}';
        add_header Content-Type application/json;
    }
    
    # Fallback for SPA routing (if we upgrade to React)
    location / {
        try_files $uri $uri/ /index.html;
    }
    
    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    
    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/xml text/javascript application/json application/javascript application/xml+rss application/rss+xml application/atom+xml image/svg+xml text/javascript application/vnd.ms-fontobject application/x-font-ttf font/opentype;
}